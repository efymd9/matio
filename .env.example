# Copy to .env.local and fill in real values.

# Postgres
DATABASE_URL=postgres://user:password@host:5432/matio

# Clerk — https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Webhooks → endpoint signing secret in the Clerk dashboard
CLERK_WEBHOOK_SIGNING_SECRET=

# Mux — https://dashboard.mux.com → Settings → Access Tokens
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
# Mux Settings → Webhooks → endpoint signing secret
MUX_WEBHOOK_SIGNING_SECRET=
# Mux Settings → Signing Keys (for signed playback URLs). Private key is base64-encoded PEM.
MUX_SIGNING_KEY_ID=
MUX_SIGNING_KEY_PRIVATE_KEY=
# Mux Data env key (Mux dashboard → the environment → Env Key). PUBLIC client-side
# token, distinct from the API token/signing key. Enables watch-time / QoE
# analytics. The player only sends Mux Data beacons when this is set AND the
# viewer accepted marketing cookies. Leave blank to keep Mux Data off.
NEXT_PUBLIC_MUX_DATA_ENV_KEY=
# Mux Data API token (a Mux access token with "Mux Data: Read" permission).
# SECRET — server-only, read by /admin/analytics to pull real watch-time into
# the dashboard. Distinct from MUX_TOKEN_* (video) and the env key above.
MUX_DATA_API_TOKEN_ID=
MUX_DATA_API_TOKEN_SECRET=

# Vercel Blob — stores admin-uploaded show artwork (poster + hero). Provision
# a store with `vercel blob store add <name>` (or Vercel dashboard → Storage →
# Create → Blob) and connect it to this project; the token is then set on all
# deployments automatically. Pull it locally with `vercel env pull .env.local`.
# Leave blank to disable image uploads (paste-a-URL still works).
BLOB_READ_WRITE_TOKEN=

# Stripe — https://dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=
# Stripe → Developers → Webhooks → endpoint signing secret (whsec_…)
STRIPE_WEBHOOK_SECRET=
# Price IDs printed by `pnpm stripe:setup`
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_ANNUAL=
# Where Checkout / Portal redirect back to.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Feature flags (Vercel Flags SDK)
# Generate FLAGS_SECRET with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
FLAGS_SECRET=
SHOW_LANDING=true

# Meta Pixel + Conversions API — https://business.facebook.com → Events Manager
# Pixel ID is public (ships in client JS); the CAPI access token is a secret.
# Both the browser Pixel and server-side CAPI are gated on marketing consent.
NEXT_PUBLIC_META_PIXEL_ID=
# Optional: extra browser pixel IDs (comma-separated) to also fire events to,
# e.g. a second ad account. Browser-only — server-side CAPI Purchase still goes
# only to NEXT_PUBLIC_META_PIXEL_ID (each pixel needs its own CAPI token).
NEXT_PUBLIC_META_PIXEL_IDS=
# Events Manager → Settings → Conversions API → Generate access token
META_CAPI_ACCESS_TOKEN=
# Optional: CAPI token for the Nth extra pixel in NEXT_PUBLIC_META_PIXEL_IDS
# (2-based, by position). Set this to also send the server-side Purchase to the
# 2nd pixel; without it that pixel stays browser-only. Add _3, _4… for more.
META_CAPI_ACCESS_TOKEN_2=
# Optional: only set while testing in the Events Manager "Test events" tab.
META_CAPI_TEST_EVENT_CODE=
# Optional: Graph API version override (defaults to v21.0 in lib/meta-capi.ts).
META_GRAPH_API_VERSION=

# PostHog (EU Cloud) funnel analytics — https://eu.posthog.com → Settings → Project
# Project API key is PUBLIC (ships in client JS) and used by BOTH the browser
# provider and the server (posthog-node) conversion event. Consent-gated: the
# SDK only loads after the viewer accepts marketing cookies. Leave KEY blank to
# keep PostHog fully off (client provider + server both no-op). See docs/posthog-funnel.md.
NEXT_PUBLIC_POSTHOG_KEY=
# Same-origin reverse-proxy path the browser SDK posts through (next.config.ts
# rewrites /ingest → eu.i.posthog.com; proxy.ts excludes /ingest from auth).
NEXT_PUBLIC_POSTHOG_HOST=/ingest
# Server SDK ingestion host (posthog-node, no proxy needed).
POSTHOG_HOST=https://eu.i.posthog.com

# Google Analytics 4 — https://analytics.google.com → Admin → Data Streams → Web.
# Measurement ID is PUBLIC (ships in client JS). gtag.js is loaded directly (no
# npm SDK) and consent-gated: it only injects after the viewer accepts marketing
# cookies, and a mid-session withdrawal flips the ga-disable kill-switch. Leave
# blank to keep GA fully off (the loader renders null). NEXT_PUBLIC is build-time
# inlined — set it in Vercel BEFORE the deploy that wants it.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Resend — transactional email (new-episode reminder notifications).
# https://resend.com → API Keys. Secret, server-only. Leave blank to keep
# email off: the series-end capture form still stores addresses in
# show_reminders, and the admin send panel degrades to a "connect Resend"
# hint. The From domain must be verified in Resend (DNS records at the
# registrar) before real sends — see docs/services.md → Resend.
RESEND_API_KEY=
# Optional sender overrides (defaults: "Matio <updates@matio.tv>" and
# reply-to hello@matio.tv).
# RESEND_FROM=
# RESEND_REPLY_TO=
